EXPO_PUBLIC_BFF_URL=http://localhost:4000
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
# Google Maps SDK (Android) — leave blank locally; the posting flow's map pin-picker won't
# render on Android until set (see docs/plans/google-maps-location-picker.md). iOS needs no
# equivalent key — it uses Apple Maps by default. Read by app.config.js's react-native-maps
# plugin entry, not by app code directly.
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=
