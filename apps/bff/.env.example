PORT=4000
DATABASE_URL="postgresql://bhavano:bhavano@localhost:5432/bhavano"
AUTH_JWT_SECRET="dev-only-change-me"
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_DLT_TEMPLATE_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated allowlist — a phone/email matching one of these gets promoted to role=admin
# automatically on login (there's no separate admin invite/signup flow).
ADMIN_PHONES=
ADMIN_EMAILS=

# Enables POST /auth/dev-login, which mints a real session for an existing (seeded) user without
# OTP/Google — used only by the web app's Playwright smoke suite (docs/plans/web-smoke-tests.md).
# Leave unset/false everywhere except your local dev environment.
ALLOW_DEV_LOGIN=false

# Notifications (moderation flag/approve emails+SMS, and the first-login welcome message). All
# optional — left blank, NotificationsService just logs instead of sending (see
# notifications/providers/email.provider.ts and notifications/providers/msg91.provider.ts).
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Requires a DLT-registered template in the MSG91 dashboard with one variable slot (VAR1) for
# the message body — arbitrary SMS content isn't deliverable in India without this.
MSG91_TRANSACTIONAL_TEMPLATE_ID=
# MSG91 WhatsApp Business API (used for the first-login welcome message) — requires a registered
# WhatsApp sender number and an approved message template in the MSG91 dashboard.
MSG91_WHATSAPP_INTEGRATED_NUMBER=
MSG91_WHATSAPP_TEMPLATE_NAME=

# Razorpay — listing boosts (see docs/plans/monetization-boosted-listings-premium-tiers.md).
# RAZORPAY_KEY_ID is also sent to the client to open Checkout; RAZORPAY_KEY_SECRET/WEBHOOK_SECRET
# never leave the server. Use a test-mode account's keys for local dev.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# From the webhook's settings page in the Razorpay dashboard, not the same as the key secret.
RAZORPAY_WEBHOOK_SECRET=

# Google Maps Platform — server-side reverse geocoding for the map pin-picker (see
# docs/plans/google-maps-location-picker.md). This key must be IP-restricted in Google Cloud
# Console (Geocoding API only) and never sent to any client — it's entirely separate from the
# web app's NEXT_PUBLIC_GOOGLE_MAPS_JS_KEY (HTTP-referrer restricted) and from GOOGLE_CLIENT_ID/
# SECRET above (Google OAuth login, an unrelated credential).
GOOGLE_MAPS_SERVER_KEY=
