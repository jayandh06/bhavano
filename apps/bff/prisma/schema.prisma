generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ListingCategory {
  house
  apartment
  villa
  pg
  storage
  coworking
  furniture
  interiors
  plot
  commercial
}

enum TransactionType {
  buy
  sell
  rent
  lease
}

enum ListingStatus {
  active
  sold
  rented
  deactivated
}

enum ListingCondition {
  new
  used
}

enum UserRole {
  user
  admin
}

/** approved = normal/visible; flagged = an admin took it offline pending a fix from the
 * owner (this IS the soft-delete — there's no separate deleted state). */
enum ModerationState {
  approved
  flagged
}

/** inquiry = buyer/seller chat about a listing; moderation = admin↔owner thread about a
 * flagged listing. Kept distinct so an admin's thread can't collide with a real buyer's. */
enum ConversationType {
  inquiry
  moderation
}

enum LoginMethod {
  otp
  google
}

enum RateLimitKind {
  publish
  view
}

enum PaymentStatus {
  created
  paid
  failed
  refunded
}

/** Only "listing_boost" exists today — buyer/seller subscription purposes are a planned
 * follow-on (see docs/plans/monetization-boosted-listings-premium-tiers.md), to be added here
 * once those flows are actually built, not preemptively. */
enum PaymentPurpose {
  listing_boost
}

model City {
  id        String    @id @default(cuid())
  name      String
  state     String
  lat       Float
  lng       Float
  isPopular Boolean   @default(false)
  listings  Listing[]
  areas     Area[]
  users     User[]

  @@unique([name, state])
}

model Area {
  id       String    @id @default(cuid())
  name     String
  cityId   String
  city     City      @relation(fields: [cityId], references: [id])
  lat      Float?
  lng      Float?
  source   String    @default("curated")
  listings Listing[]

  @@unique([name, cityId])
  @@index([cityId])
}

model User {
  id                    String         @id @default(cuid())
  phone                 String?        @unique
  phoneVerifiedAt       DateTime?
  email                 String?        @unique
  googleId              String?        @unique
  name                  String?
  role                  UserRole       @default(user)
  cityId                String?
  city                  City?          @relation(fields: [cityId], references: [id])
  createdAt             DateTime       @default(now())
  listings              Listing[]
  favourites            Favourite[]
  conversationsAsPoster Conversation[] @relation("ConversationPoster")
  conversationsAsInquirer Conversation[] @relation("ConversationInquirer")
  messages              Message[]
  loginEvents           LoginEvent[]
  payments              Payment[]

  @@index([cityId])
}

model Listing {
  id               String            @id @default(cuid())
  category         ListingCategory
  transactionType  TransactionType
  status           ListingStatus     @default(active)
  moderationState  ModerationState   @default(approved)
  adminReviewed    Boolean           @default(false)
  moderatedAt      DateTime?
  condition        ListingCondition?
  price            Int
  priceQualifier   String            @default("")
  title            String
  slug             String
  areaId           String
  area             Area              @relation(fields: [areaId], references: [id])
  cityId           String
  city             City              @relation(fields: [cityId], references: [id])
  lat              Float?
  lng              Float?
  tag              String
  specs            String[]          @default([])
  attributes       Json              @default("{}")
  ownerId          String
  owner            User              @relation(fields: [ownerId], references: [id])
  relatedListingId String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  expiresAt        DateTime
  viewCount        Int               @default(0)
  likeCount        Int               @default(0)
  // Denormalized from ListingBoost (the audit trail) so the hot-path browse query never needs
  // a join just to check boost status — null means not currently boosted. boostRank is bumped
  // by a periodic job to rotate tie-order among simultaneously-boosted listings, rather than
  // whoever paid first/most permanently squatting the top slot.
  boostedUntil     DateTime?
  boostRank        Float?
  listingPhotos    ListingPhoto[]
  views            ListingView[]
  favourites       Favourite[]
  conversations    Conversation[]
  payments         Payment[]
  listingBoosts    ListingBoost[]

  @@index([cityId, category])
  @@index([cityId, transactionType])
  @@index([expiresAt])
  @@index([boostedUntil])
}

/** One row per unique viewer (logged-in user id or anonymous device key) — used to
 * dedupe Listing.viewCount so repeat visits from the same viewer don't inflate it. */
model ListingView {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  viewerKey String
  createdAt DateTime @default(now())

  @@unique([listingId, viewerKey])
  @@index([viewerKey])
}

model Favourite {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([listingId, userId])
}

model Conversation {
  id          String           @id @default(cuid())
  listingId   String
  listing     Listing          @relation(fields: [listingId], references: [id], onDelete: Cascade)
  posterId    String
  poster      User             @relation("ConversationPoster", fields: [posterId], references: [id])
  inquirerId  String
  inquirer    User             @relation("ConversationInquirer", fields: [inquirerId], references: [id])
  type        ConversationType @default(inquiry)
  createdAt   DateTime         @default(now())
  messages    Message[]

  @@unique([listingId, inquirerId, type])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  body           String
  createdAt      DateTime     @default(now())
  readAt         DateTime?

  @@index([conversationId, createdAt])
}

/** One row per photo on a listing — ordered by photoNo, hash retained for the existing
 * near-duplicate check at moderation time. Variant URLs (preview/full) are never stored
 * here; they're fully derived from listingId + photoNo (see apps/bff/src/uploads/photo-keys.ts). */
model ListingPhoto {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  photoNo   Int
  hash      String
  createdAt DateTime @default(now())

  @@unique([listingId, photoNo])
  @@index([hash])
}

enum PhotoVariantType {
  preview
  full
}

enum PhotoJobStatus {
  pending
  processing
  done
  failed
}

/** Durable work queue for async photo resizing — polled in-process (no Redis/queue infra).
 * No FK to Listing: jobs are only created once the listing already exists (from
 * ListingsService.create(), not from the upload step, which runs before the listing does). */
model PhotoVariantJob {
  id        String           @id @default(cuid())
  listingId String
  photoNo   Int
  ext       String
  variant   PhotoVariantType
  status    PhotoJobStatus   @default(pending)
  attempts  Int              @default(0)
  error     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([status, createdAt])
}

model OtpChallenge {
  id        String   @id @default(cuid())
  phone     String
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone])
}

model LoginEvent {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  method    LoginMethod
  createdAt DateTime    @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

/** One row per rate-limited action attempt, counted over a rolling window at check time —
 * not pruned (same non-cleanup precedent as OtpChallenge). Anonymous requests never reach
 * the guard that writes these, so `identity` is always "user:<id>". */
model RateLimitHit {
  id        String        @id @default(cuid())
  identity  String
  kind      RateLimitKind
  createdAt DateTime      @default(now())

  @@index([identity, kind, createdAt])
}

/** Singleton row (fixed id "singleton", upserted) — the admin-editable rate limits. */
model RateLimitSetting {
  id                   String   @id
  publishLimit         Int      @default(5)
  publishWindowMinutes Int      @default(1440)
  viewLimit            Int      @default(200)
  viewWindowMinutes    Int      @default(60)
  updatedAt            DateTime @updatedAt
}

/** Central payment ledger — the single source of truth for whether a purchase actually
 * succeeded. The Razorpay webhook (never a client-side "payment succeeded" callback) is what
 * flips a row to `paid`; `razorpayPaymentId` is unique so webhook redelivery is always a safe
 * no-op. `listingId`/`boostDays` are purpose-specific fields (only meaningful for
 * `listing_boost`) — left nullable rather than modeled generically, same pattern as
 * `Listing.condition` being furniture-only; future purposes add their own nullable fields in
 * their own migration instead of retrofitting a generic column now. */
model Payment {
  id                String         @id @default(cuid())
  userId            String
  user              User           @relation(fields: [userId], references: [id])
  razorpayOrderId   String         @unique
  razorpayPaymentId String?        @unique
  amount            Int
  currency          String         @default("INR")
  status            PaymentStatus  @default(created)
  purpose           PaymentPurpose
  listingId         String?
  listing           Listing?       @relation(fields: [listingId], references: [id])
  boostDays         Int?
  createdAt         DateTime       @default(now())
  paidAt            DateTime?
  listingBoost      ListingBoost?

  @@index([userId, createdAt])
}

/** One row per activated boost — the history/audit trail. `Listing.boostedUntil` is the
 * denormalized field the hot-path browse query actually reads, kept in sync here so listing
 * queries never need a join just to check boost status. */
model ListingBoost {
  id           String   @id @default(cuid())
  listingId    String
  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  paymentId    String   @unique
  payment      Payment  @relation(fields: [paymentId], references: [id])
  boostedFrom  DateTime @default(now())
  boostedUntil DateTime

  @@index([listingId])
}
