{
  "id": null,
  "uid": "bff-overview",
  "title": "BFF Overview",
  "timezone": "Asia/Kolkata",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request rate (by level)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({service=\"bff\"} [$__auto]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"bff\", level=\"error\"} [$__auto]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Latency (p50 / p95 / p99, ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "quantile_over_time(0.5, {service=\"bff\"} | json | unwrap responseTime [$__auto])",
          "refId": "A",
          "legendFormat": "p50"
        },
        {
          "expr": "quantile_over_time(0.95, {service=\"bff\"} | json | unwrap responseTime [$__auto])",
          "refId": "B",
          "legendFormat": "p95"
        },
        {
          "expr": "quantile_over_time(0.99, {service=\"bff\"} | json | unwrap responseTime [$__auto])",
          "refId": "C",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "title": "Top endpoints by traffic",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "topk(10, sum by (url) (count_over_time({service=\"bff\"} | json [$__auto])))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Recent errors",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service=\"bff\", level=\"error\"}",
          "refId": "A"
        }
      ]
    }
  ]
}
