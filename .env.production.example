# Copy to .env on the EC2 host, fill in real values, then:
#   docker compose -f docker-compose.prod.yml --env-file .env up -d --build

# Caddy — your real domains, DNS A records must point at this instance first
SITE_DOMAIN=www.bhavano.example.com
API_DOMAIN=api.bhavano.example.com
# Bare apex — Caddy 308-redirects this to SITE_DOMAIN rather than serving it directly
APEX_DOMAIN=bhavano.example.com
# Admin moderation app — keep this off any public link/nav; only admins should know it exists
ADMIN_DOMAIN=admin.bhavano.example.com
# Grafana (logging/observability) — same idea as ADMIN_DOMAIN, not linked from public nav
LOGS_DOMAIN=logs.bhavano.example.com

# RDS Postgres endpoint (not a container — see recommendation to keep the DB managed/separate)
DATABASE_URL="postgresql://bhavano:CHANGE_ME@your-rds-endpoint.rds.amazonaws.com:5432/bhavano"

# Web
NEXT_PUBLIC_BFF_URL="https://api.bhavano.example.com"
NEXT_PUBLIC_SITE_URL="https://bhavano.example.com"
# Google Tag Manager container ID — leave blank to skip loading GTM entirely (e.g. locally).
NEXT_PUBLIC_GTM_ID=
# Google Maps JavaScript API + Places — the posting flow's map pin-picker (see
# docs/plans/google-maps-location-picker.md). Sent to the browser, so restrict it by HTTP
# referrer (your domain) in Google Cloud Console — never reuse GOOGLE_MAPS_SERVER_KEY below here.
NEXT_PUBLIC_GOOGLE_MAPS_JS_KEY=
NEXTAUTH_URL="https://bhavano.example.com"
NEXTAUTH_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING"
AUTH_TRUST_HOST=true

# Admin app — separate NextAuth session from the public site (different secret/cookie),
# same BFF login endpoints under the hood.
ADMIN_NEXTAUTH_URL="https://admin.bhavano.example.com"
ADMIN_NEXTAUTH_SECRET="CHANGE_ME_TO_A_DIFFERENT_LONG_RANDOM_STRING"

# BFF
AUTH_JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING"
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_DLT_TEMPLATE_ID=

# No admin signup flow exists — a phone/email matching one of these (comma-separated) gets
# promoted to role=admin automatically on login. Set these before anyone logs in as admin.
ADMIN_PHONES=
ADMIN_EMAILS=

# Notifications sent to a listing's owner when an admin flags/approves it, and the first-login
# welcome message — all optional, left blank just logs instead of sending (see
# apps/bff/src/notifications).
RESEND_API_KEY=
RESEND_FROM_EMAIL="Bhavano <notifications@bhavano.example.com>"
# Requires a DLT-registered template in the MSG91 dashboard (India regulation — arbitrary SMS
# content isn't deliverable without one) with a single variable slot (VAR1) for the message body.
MSG91_TRANSACTIONAL_TEMPLATE_ID=
# MSG91 WhatsApp Business API (welcome message) — requires a registered WhatsApp sender number
# and an approved message template in the MSG91 dashboard.
MSG91_WHATSAPP_INTEGRATED_NUMBER=
MSG91_WHATSAPP_TEMPLATE_NAME=

# Photo storage — Cloudflare R2 (S3-compatible) + a custom-domain CDN in front of it.
# See "Photo storage (Cloudflare R2 + CDN)" in docs/deployment.md for how to create these.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
CDN_BASE_URL="https://cdn.bhavano.example.com"

# Shared (both web's NextAuth Google provider and bff's /auth/google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Grafana admin login — see "Logging & observability (Loki + Grafana)" in docs/deployment.md
GRAFANA_ADMIN_PASSWORD="CHANGE_ME_TO_A_LONG_RANDOM_STRING"

# Razorpay — listing boosts, see docs/plans/monetization-boosted-listings-premium-tiers.md.
# Use live-mode keys here; RAZORPAY_KEY_SECRET/WEBHOOK_SECRET never reach the client.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Google Maps — server-side reverse geocoding for the map pin-picker (see
# docs/plans/google-maps-location-picker.md). IP-restrict this in Google Cloud Console
# (Geocoding API only); it must never be sent to any client — separate from
# NEXT_PUBLIC_GOOGLE_MAPS_JS_KEY above and from GOOGLE_CLIENT_ID/SECRET (Google OAuth login).
GOOGLE_MAPS_SERVER_KEY=
