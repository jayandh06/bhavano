# Copy to .env on the EC2 host, fill in real values, then:
#   docker compose -f docker-compose.prod.yml --env-file .env up -d --build

# Caddy — your real domains, DNS A records must point at this instance first
SITE_DOMAIN=www.bhavano.example.com
API_DOMAIN=api.bhavano.example.com
# Bare apex — Caddy 308-redirects this to SITE_DOMAIN rather than serving it directly
APEX_DOMAIN=bhavano.example.com
# Admin moderation app — keep this off any public link/nav; only admins should know it exists
ADMIN_DOMAIN=admin.bhavano.example.com

# RDS Postgres endpoint (not a container — see recommendation to keep the DB managed/separate)
DATABASE_URL="postgresql://bhavano:CHANGE_ME@your-rds-endpoint.rds.amazonaws.com:5432/bhavano"

# Web
NEXT_PUBLIC_BFF_URL="https://api.bhavano.example.com"
NEXT_PUBLIC_SITE_URL="https://bhavano.example.com"
NEXTAUTH_URL="https://bhavano.example.com"
NEXTAUTH_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING"
AUTH_TRUST_HOST=true

# Admin app — separate NextAuth session from the public site (different secret/cookie),
# same BFF login endpoints under the hood.
ADMIN_NEXTAUTH_URL="https://admin.bhavano.example.com"
ADMIN_NEXTAUTH_SECRET="CHANGE_ME_TO_A_DIFFERENT_LONG_RANDOM_STRING"

# BFF
AUTH_JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING"
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_DLT_TEMPLATE_ID=

# No admin signup flow exists — a phone/email matching one of these (comma-separated) gets
# promoted to role=admin automatically on login. Set these before anyone logs in as admin.
ADMIN_PHONES=
ADMIN_EMAILS=

# Notifications sent to a listing's owner when an admin flags/approves it — both optional,
# left blank just logs instead of sending (see apps/bff/src/notifications).
RESEND_API_KEY=
RESEND_FROM_EMAIL="Bhavano <notifications@bhavano.example.com>"
# Requires a DLT-registered template in the MSG91 dashboard (India regulation — arbitrary SMS
# content isn't deliverable without one) with a single variable slot (VAR1) for the message body.
MSG91_TRANSACTIONAL_TEMPLATE_ID=

# Shared (both web's NextAuth Google provider and bff's /auth/google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
